# Copie para .env e preencha. NUNCA commitar o .env (está no .gitignore).

# === Steam ===
# GSLT do servidor (https://steamcommunity.com/dev/managegameservers, App ID 730).
# Sem isso o servidor só funciona em LAN/local.
SRCDS_TOKEN=
# Steam Web API key para o login OpenID do site (https://steamcommunity.com/dev/apikey).
STEAM_API_KEY=

# === Servidor CS2 ===
CS2_SERVERNAME=CS2 Docker BR
CS2_RCONPW=troque-esta-senha-rcon
# Senha de entrada no servidor (vazio = sem senha).
CS2_PW=
CS2_MAXPLAYERS=12
CS2_GAMEALIAS=competitive
CS2_MAPGROUP=mg_active
CS2_STARTMAP=de_inferno
CS2_SERVER_HIBERNATE=0
STEAMAPPVALIDATE=0

# === Banco de dados (compartilhado entre plugin e site) ===
DB_NAME=cs2skins
DB_USER=cs2
DB_PASSWORD=troque-esta-senha-db
DB_ROOT_PASSWORD=troque-esta-senha-root

# === Site de skins ===
WEB_PORT=8080
WEB_URL=http://localhost:8080
WP_LANG=en
